              background: body.classList.contains("dark-mode")
                ? "#0f172a"
                : "#ffffff",
              color: body.classList.contains("dark-mode")
                ? "#ffffff"
                : "#111827",
            });
          }
        }
      });
    </script>
  </body>
</html>
