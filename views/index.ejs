<!DOCTYPE html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>Dashboard — SecureAuth</title>

    <link
      rel="icon"
      href="data:image/svg+xml,<svg xmlns=%22http://www.w3.org/2000/svg%22 viewBox=%220 0 100 100%22><rect width=%22100%22 height=%22100%22 rx=%2220%22 fill=%22%237c3aed%22/></svg>"
    />

    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />

    <link
      href="https://fonts.googleapis.com/css2?family=Plus+Jakarta+Sans:wght@400;500;600;700&display=swap"
      rel="stylesheet"
    />

    <script src="https://unpkg.com/lucide@latest/dist/umd/lucide.min.js"></script>
    <script src="https://cdn.jsdelivr.net/npm/sweetalert2@11"></script>

    <style>
      *,
      *::before,
      *::after {
        margin: 0;
        padding: 0;
        box-sizing: border-box;
      }

      :root {
        --font: "Plus Jakarta Sans", sans-serif;

        --bg: #f4f2ff;
        --card-bg: #ffffff;
        --card-border: rgba(124, 58, 237, 0.14);

        --chip-bg: #f5f3ff;
        --chip-border: rgba(124, 58, 237, 0.14);

        --text-primary: #1a1033;
        --text-secondary: #6b7280;
        --text-hint: #9ca3af;

        --divider: #ede9fe;
        --icon-color: #8b5cf6;

        --card-shadow:
          0 10px 50px rgba(124, 58, 237, 0.12),
          0 4px 12px rgba(124, 58, 237, 0.08);

        --ease: cubic-bezier(0.4, 0, 0.2, 1);
      }

      body.dark {
        --bg: #09060f;
        --card-bg: #120d24;
        --card-border: rgba(167, 139, 250, 0.14);

        --chip-bg: #1a1235;
        --chip-border: rgba(167, 139, 250, 0.14);

        --text-primary: #f5f3ff;
        --text-secondary: #b4abc9;
        --text-hint: #746b94;

        --divider: #241b44;
        --icon-color: #a78bfa;

        --card-shadow:
          0 8px 48px rgba(0, 0, 0, 0.55), 0 2px 8px rgba(124, 58, 237, 0.18);
      }

      html {
        font-size: 16px;
      }

      body {
        font-family: var(--font);
        background: var(--bg);
        color: var(--text-primary);

        min-height: 100vh;

        display: flex;
        justify-content: center;
        align-items: center;

        padding: 1rem;

        overflow-x: hidden;

        position: relative;

        transition:
          background 0.35s var(--ease),
          color 0.3s var(--ease);
      }

      /* BLOBS */

      .blob {
        position: fixed;
        border-radius: 50%;
        pointer-events: none;
        z-index: 0;
      }

      .blob-1 {
        width: 500px;
        height: 500px;
        top: -160px;
        left: -160px;

        background: radial-gradient(
          circle,
          rgba(124, 58, 237, 0.24) 0%,
          transparent 65%
        );
      }

      .blob-2 {
        width: 350px;
        height: 350px;
        bottom: -100px;
        right: -100px;

        background: radial-gradient(
          circle,
          rgba(167, 139, 250, 0.2) 0%,
          transparent 65%
        );
      }

      /* THEME BUTTON */

      .theme-btn {
        position: fixed;
        top: 1rem;
        right: 1rem;

        width: 44px;
        height: 44px;

        border-radius: 50%;
        border: 1px solid var(--card-border);

        background: var(--card-bg);

        display: flex;
        align-items: center;
        justify-content: center;

        cursor: pointer;

        z-index: 999;

        color: var(--text-secondary);

        transition: 0.25s ease;
      }

      .theme-btn:hover {
        transform: rotate(15deg) scale(1.06);
        color: #7c3aed;
      }

      /* CARD */

      .card {
        width: 100%;
        max-width: 540px;

        background: var(--card-bg);

        border: 1px solid var(--card-border);

        border-radius: 24px;

        padding: 2.5rem 2rem;

        position: relative;
        z-index: 2;

        box-shadow: var(--card-shadow);

        text-align: center;

        animation: fadeUp 0.45s ease;
      }

      @keyframes fadeUp {
        from {
          opacity: 0;
          transform: translateY(20px);
        }

        to {
          opacity: 1;
          transform: translateY(0);
        }
      }

      /* LOGO */

      .logo-wrap {
        width: 70px;
        height: 70px;

        margin: 0 auto 1.5rem;

        border-radius: 20px;

        background: linear-gradient(135deg, #7c3aed, #a78bfa);

        display: flex;
        align-items: center;
        justify-content: center;

        color: white;

        box-shadow: 0 8px 24px rgba(124, 58, 237, 0.35);
      }

      /* BADGE */

      .badge {
        display: inline-flex;
        align-items: center;
        gap: 6px;

        padding: 5px 12px;

        border-radius: 999px;

        background: rgba(34, 197, 94, 0.12);

        border: 1px solid rgba(34, 197, 94, 0.2);

        color: #16a34a;

        font-size: 0.76rem;
        font-weight: 600;

        margin-bottom: 1rem;
      }

      .badge-dot {
        width: 6px;
        height: 6px;

        border-radius: 50%;

        background: #22c55e;
      }

      /* TEXT */

      h1 {
        font-size: 2rem;
        margin-bottom: 0.5rem;
      }

      .subtitle {
        color: var(--text-secondary);

        line-height: 1.7;

        max-width: 360px;

        margin: 0 auto 2rem;
      }

      /* STATS */

      .stats {
        display: grid;
        grid-template-columns: repeat(3, 1fr);

        gap: 12px;

        margin-bottom: 2rem;
      }

      .stat {
        background: var(--chip-bg);

        border: 1px solid var(--chip-border);

        border-radius: 16px;

        padding: 1rem;

        transition: 0.2s ease;
      }

      .stat:hover {
        transform: translateY(-3px);
      }

      .stat-icon {
        width: 42px;
        height: 42px;

        margin: 0 auto 10px;

        border-radius: 12px;

        display: flex;
        align-items: center;
        justify-content: center;
      }

      .purple {
        background: rgba(124, 58, 237, 0.12);
        color: #7c3aed;
      }

      .green {
        background: rgba(34, 197, 94, 0.12);
        color: #16a34a;
      }

      .blue {
        background: rgba(59, 130, 246, 0.12);
        color: #2563eb;
      }

      .stat-label {
        font-size: 0.72rem;
        text-transform: uppercase;
        letter-spacing: 0.05em;

        color: var(--text-hint);

        margin-bottom: 4px;
      }

      .stat-value {
        font-weight: 700;
      }

      /* FEATURES */

      .features {
        display: flex;
        flex-wrap: wrap;
        justify-content: center;

        gap: 10px;

        margin-bottom: 2rem;
      }

      .chip {
        display: inline-flex;
        align-items: center;
        gap: 8px;

        padding: 10px 15px;

        border-radius: 12px;

        background: var(--chip-bg);

        border: 1px solid var(--chip-border);

        font-size: 0.84rem;
        font-weight: 500;
      }

      /* DIVIDER */

      .divider {
        display: flex;
        align-items: center;

        gap: 10px;

        margin-bottom: 1.5rem;

        color: var(--text-hint);

        font-size: 0.8rem;
      }

      .divider::before,
      .divider::after {
        content: "";

        flex: 1;

        height: 1px;

        background: var(--divider);
      }

      /* BUTTONS */

      .action-row {
        display: flex;
        flex-wrap: wrap;
        justify-content: center;

        gap: 12px;

        width: 100%;
      }

      .github-btn,
      .logout-btn {
        display: inline-flex;
        align-items: center;
        justify-content: center;
        gap: 8px;

        min-width: 180px;

        padding: 13px 18px;

        border-radius: 14px;

        text-decoration: none;

        font-weight: 600;
        font-size: 0.9rem;

        cursor: pointer;

        transition: 0.2s ease;
      }

      .github-btn {
        background: var(--chip-bg);

        border: 1px solid var(--chip-border);

        color: var(--text-primary);
      }

      .github-btn:hover {
        transform: translateY(-2px);

        border-color: rgba(124, 58, 237, 0.45);

        color: #7c3aed;
      }

      .logout-btn {
        border: none;

        background: linear-gradient(135deg, #ef4444, #dc2626);

        color: white;
      }

      .logout-btn:hover {
        transform: translateY(-2px);
      }

      /* FOOTER */

      .footer-txt {
        margin-top: 1.8rem;

        font-size: 0.8rem;

        color: var(--text-hint);
      }

      /* MOBILE */

      @media (max-width: 768px) {
        .card {
          max-width: 95%;
        }

        .stats {
          grid-template-columns: repeat(2, 1fr);
        }

        .stats .stat:last-child {
          grid-column: span 2;
        }
      }

      @media (max-width: 480px) {
        body {
          padding: 0.8rem;
        }

        .card {
          padding: 1.7rem 1rem;
          border-radius: 20px;
        }

        h1 {
          font-size: 1.5rem;
        }

        .subtitle {
          font-size: 0.85rem;
        }

        .stats {
          grid-template-columns: 1fr;
        }

        .stats .stat:last-child {
          grid-column: span 1;
        }

        .action-row {
          flex-direction: column;
        }

        .github-btn,
        .logout-btn {
          width: 100%;
        }

        .features {
          flex-direction: column;
        }

        .chip {
          width: 100%;
          justify-content: center;
        }
      }
    </style>
  </head>

  <body>
    <!-- BLOBS -->

    <div class="blob blob-1"></div>
    <div class="blob blob-2"></div>

    <!-- THEME BUTTON -->

    <button class="theme-btn" id="themeBtn">
      <i data-lucide="moon" width="18" height="18"></i>
    </button>

    <!-- CARD -->

    <main class="card">
      <div class="logo-wrap">
        <i data-lucide="layout-dashboard" width="30" height="30"></i>
      </div>

      <div class="badge">
        <span class="badge-dot"></span>
        Session Active
      </div>

      <h1>Dashboard</h1>

      <p class="subtitle">
        Your account is authenticated and your session is secure. Everything is
        ready to go.
      </p>

      <!-- STATS -->

      <div class="stats">
        <div class="stat">
          <div class="stat-icon purple">
            <i data-lucide="shield-check" width="18" height="18"></i>
          </div>

          <div class="stat-label">Status</div>

          <div class="stat-value">Verified</div>
        </div>

        <div class="stat">
          <div class="stat-icon green">
            <i data-lucide="zap" width="18" height="18"></i>
          </div>

          <div class="stat-label">Speed</div>

          <div class="stat-value">Fast</div>
        </div>

        <div class="stat">
          <div class="stat-icon blue">
            <i data-lucide="lock" width="18" height="18"></i>
          </div>

          <div class="stat-label">Auth</div>

          <div class="stat-value">JWT</div>
        </div>
      </div>

      <!-- FEATURES -->

      <div class="features">
        <div class="chip">
          <i data-lucide="shield" width="15" height="15"></i>
          Secure Access
        </div>

        <div class="chip">
          <i data-lucide="zap" width="15" height="15"></i>
          Fast Experience
        </div>

        <div class="chip">
          <i data-lucide="key" width="15" height="15"></i>
          Protected Session
        </div>
      </div>

      <!-- DIVIDER -->

      <div class="divider">session options</div>

      <!-- BUTTONS -->

      <div class="action-row">
        <!-- GITHUB -->

        <a
          href="https://github.com/git-shubham-side/JWT-Auth-Implementation"
          target="_blank"
          class="github-btn"
        >
          <i data-lucide="app-window" width="17" height="17"></i>

          Integrate into your Application
        </a>

        <!-- SIGNUP -->

        <a href="/signup" class="github-btn">
          <i data-lucide="user-plus" width="17" height="17"></i>

          Signup
        </a>

        <!-- LOGIN -->

        <a href="/login" class="github-btn">
          <i data-lucide="log-in" width="17" height="17"></i>

          Login
        </a>

        <!-- LOGOUT -->

        <!--
        <button class="logout-btn" id="logoutBtn">
          <i data-lucide="log-out" width="17" height="17"></i>
          Logout
        </button>
        -->
      </div>

      <p class="footer-txt">Authentication System — SecureAuth</p>
    </main>

    <script>
      lucide.createIcons();

      // THEME

      const body = document.body;
      const themeBtn = document.getElementById("themeBtn");

      function applyTheme(isDark) {
        body.classList.toggle("dark", isDark);

        localStorage.setItem("theme", isDark ? "dark" : "light");

        themeBtn.innerHTML = isDark
          ? `<i data-lucide="sun" width="18" height="18"></i>`
          : `<i data-lucide="moon" width="18" height="18"></i>`;

        lucide.createIcons();
      }

      (() => {
        const saved = localStorage.getItem("theme");

        const prefersDark = window.matchMedia(
          "(prefers-color-scheme: dark)",
        ).matches;

        applyTheme(saved === "dark" || (!saved && prefersDark));
      })();

      themeBtn.addEventListener("click", () => {
        applyTheme(!body.classList.contains("dark"));
      });

      // LOGOUT

      const logoutBtn = document.getElementById("logoutBtn");

      if (logoutBtn) {
        logoutBtn.addEventListener("click", async () => {
          const result = await Swal.fire({
            title: "Logout?",
            text: "Are you sure you want to logout?",
            icon: "warning",
            showCancelButton: true,
            confirmButtonColor: "#7c3aed",
            cancelButtonColor: "#dc2626",
            confirmButtonText: "Yes",
          });

          if (!result.isConfirmed) return;

          try {
            const res = await fetch("/logout");

            if (res.ok) {
              await Swal.fire({
                icon: "success",
                title: "Logged out",
                timer: 1500,
                showConfirmButton: false,
              });

              window.location.href = "/login";
            }
          } catch (err) {
            Swal.fire({
              icon: "error",
              title: "Something went wrong",
            });
          }
        });
      }
    </script>
  </body>
</html>
