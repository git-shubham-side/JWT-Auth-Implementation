<!DOCTYPE html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>Authentication - By Shubham Rathod</title>
    <link
      rel="icon"
      href="data:image/svg+xml,<svg xmlns=%22http://www.w3.org/2000/svg%22 viewBox=%220 0 100 100%22><text y=%22.9em%22 font-size=%2290%22>🔐</text></svg>"
    />

    <!-- Google Font -->
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      href="https://fonts.googleapis.com/css2?family=Poppins:wght@300;400;500;600;700&display=swap"
      rel="stylesheet"
    />
    <link rel="stylesheet" href="/style.css" />
  </head>

  <body>
    <!-- Background Blur -->
    <div class="bg-blur blur-1"></div>
    <div class="bg-blur blur-2"></div>

    <!-- Theme Toggle -->
    <button class="theme-toggle" id="themeToggle">🌙</button>

    <main class="container">
      <section class="card">
        <div class="badge">✨ Secure Authentication using JWT & Bcrypt</div>

        <h1>
          Welcome to your
          <span>Authentication App</span>
        </h1>

        <p>Created by - Shubham Rathod</p>

        <div class="features">
          <div class="feature-box">🛡️ Secure</div>

          <div class="feature-box">⚡ Fast</div>

          <div class="feature-box">📱 Responsive</div>
        </div>

        <div class="buttons">
          <a href="/signup" class="btn signup-btn"> ➕ Signup </a>

          <a href="/login" class="btn login-btn"> 🔓 Login </a>
        </div>
      </section>
    </main>

    <script>
      const themeToggle = document.getElementById("themeToggle");
      const body = document.body;

      // Default Theme = Light
      body.classList.add("light-mode");

      // Load Saved Theme
      const savedTheme = localStorage.getItem("theme");

      if (savedTheme === "dark") {
        body.classList.remove("light-mode");
        themeToggle.textContent = "☀️";
      }

      themeToggle.addEventListener("click", () => {
        body.classList.toggle("light-mode");

        if (body.classList.contains("light-mode")) {
          localStorage.setItem("theme", "light");
          themeToggle.textContent = "🌙";
        } else {
          localStorage.setItem("theme", "dark");
          themeToggle.textContent = "☀️";
        }
      });
    </script>
  </body>
</html>
